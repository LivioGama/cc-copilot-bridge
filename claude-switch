# === Main ===
main() {
  local mode="${1:-}"
  shift 2>/dev/null || true

  case "${mode}" in
    d|direct)  _run_direct "$@" ;;
    c|copilot) _run_copilot "$@" ;;
    o|ollama)  _run_ollama "$@" ;;
    j|junie)   _run_junie "$@" ;;
    s|status)  _show_status ;;
    --shell-config) _print_shell_config ;;
    -v|--version) echo "claude-switch v1.8.0" ;;
    -h|--help|"") _show_usage ;;
    *)
      _log "ERROR" "Unknown mode: ${mode}"
      _show_usage
      exit 1
      ;;
  esac
}

main "$@"
